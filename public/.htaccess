# HolySword Framework - Apache 重写规则
#
# 该文件配置 Apache 服务器的 URL 重写规则，将所有请求转发到 index.php。
# 这是单入口模式（Front Controller Pattern）的核心配置。
#
# 要求：
# - Apache 服务器
# - 启用 mod_rewrite 模块
# - AllowOverride All 配置
#
# Nginx 用户请参考：
# location / {
#     try_files $uri $uri/ /index.php?$query_string;
# }
#
# @package    HolySword
# @subpackage Public
# @author     HolySword Team
# @version    1.0.0

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        # 禁用 MultiViews 和目录索引
        # - MultiViews: 防止 Apache 自动符号匹配扩展名
        # - Indexes: 禁止显示目录列表，增强安全性
        Options -MultiViews -Indexes
    </IfModule>

    # 启用 URL 重写引擎
    RewriteEngine On

    # 处理 Authorization 请求头
    # 某些 Apache 配置会删除 Authorization 头，这里将其保存到环境变量
    # 以便 PHP 能够读取 Bearer Token 等认证信息
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # 移除尾部斜杠（如果不是目录）
    # 将 /path/ 重定向到 /path，保持 URL 一致性
    # 301 永久重定向有利于 SEO
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # 核心重写规则：将所有请求发送到前端控制器
    # 如果请求的不是实际存在的目录或文件，
    # 则将请求转发到 index.php 由框架路由系统处理
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
